# ===== App =====
APP_NAME="PUG Legal Case Control System"
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-please-use-a-long-random-string

# ===== Database =====
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/pug_legal

# ===== Redis =====
REDIS_URL=redis://127.0.0.1:6379/0

# ===== JWT =====
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# ===== Storage =====
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=../storage
BACKUP_LOCAL_PATH=../backups

# ===== CORS =====
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ===== Logging =====
LOG_LEVEL=INFO
LOG_JSON=false

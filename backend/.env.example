# ===== App =====
APP_NAME="PUG Legal Case Control System"
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-please-use-a-long-random-string

# ===== Database =====
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/pug_legal

# ===== Redis =====
REDIS_URL=redis://127.0.0.1:6379/0

# ===== JWT =====
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# ===== Storage =====
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=../storage
BACKUP_LOCAL_PATH=../backups

# ===== CORS =====
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ===== Logging =====
LOG_LEVEL=INFO
LOG_JSON=false

# ===== SMTP (leave SMTP_HOST blank for console-only mode) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@pug.local
SMTP_FROM_NAME=PUG Legal Case Control System

# ===== Branding =====
BRAND_COMPANY_NAME=Paris United Group Holding
BRAND_APP_URL=http://127.0.0.1:3000

# ===== Backups =====
# 32 raw bytes, base64-encoded (e.g. python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())").
# Leave blank to disable encryption (NOT recommended for production).
BACKUP_ENCRYPTION_KEY=

# ===== Hardening (Phase 12) =====
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_LOGIN_PER_HOUR=100
# Leave SENTRY_DSN blank to disable Sentry.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
